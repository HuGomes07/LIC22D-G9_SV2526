LIBRARY ieee;
USE ieee.std_logic_1164.all;

ENTITY RG10 IS
PORT(	D : in  std_logic_vector(3 downto 0);
		Q : out STD_LOGIC_vector(3 downto 0);
		CLK, Reset : IN STD_LOGIC
		);
END RG10;

ARCHITECTURE logicFunction OF RG10 IS
BEGIN
	
	FDD0: entity work.FFD port
		map (CLK=>CLK, RESET =>Reset,D=>D(0), Q=>Q(0), SET =>'0', EN=>'1');
	FDD1: entity work.FFD port
		map (CLK=>CLK, RESET =>Reset,D=>D(1), Q=>Q(1), SET =>'0', EN=>'1');
	FDD2: entity work.FFD port
		map (CLK=>CLK, RESET =>Reset,D=>D(2), Q=>Q(2), SET =>'0', EN=>'1');
	FDD3: entity work.FFD port
		map (CLK=>CLK, RESET =>Reset,D=>D(3), Q=>Q(3), SET =>'0', EN=>'1');


END LogicFunction;